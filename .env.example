BOT_TOKEN=123456:ABC-your-bot-token
ADMIN_IDS=123456789
DB_URL=sqlite+aiosqlite:///bot.db

# https://my.telegram.org → API development tools
# Нужны, чтобы постить от аккаунта клиента (не от бота)
TG_API_ID=12345678
TG_API_HASH=your_api_hash_here

# Опционально: отдельный ключ шифрования сессий (по умолчанию = BOT_TOKEN)
# SESSION_SECRET=random_long_string

# Vercel / внешний cron: секрет для /cron?secret=...
# CRON_SECRET=random_long_string
